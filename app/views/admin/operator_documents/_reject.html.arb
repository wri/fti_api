dialog id: dialog_id, title: I18n.t("active_admin.reject") + " " + resource.name do
  active_admin_form_for resource, as: :operator_document, url: reject_admin_operator_document_path(resource), method: :put,
    html: {data: {remote: true}, class: "vertical-form"} do |f|
    f.semantic_errors(*f.object.errors.attribute_names)

    f.inputs do
      f.input :admin_comment, as: :text, hint: I18n.t("operator_documents.qc_form.admin_comment_hint"),
        input_html: {rows: 4, style: "min-width: 450px;"}
    end

    f.actions do
      f.cancel_link "javascript:void(0)", class: "close-dialog-button"
      f.action :submit, label: I18n.t("active_admin.reject"), data: {disable_with: I18n.t("active_admin.rejecting")}
    end
  end
end
