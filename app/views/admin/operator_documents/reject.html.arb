return_to = params[:return_to] || request.referer || resource_path(resource)

active_admin_form_for resource, as: :operator_document, url: reject_admin_operator_document_path(resource), method: :put do |f|
  f.semantic_errors(*f.object.errors.attribute_names)
  f.hidden_field :return_to, name: :return_to, value: return_to if return_to.present?

  f.inputs do
    f.input :admin_comment, as: :text, hint: I18n.t("operator_documents.qc_form.admin_comment_hint")
  end

  f.actions do
    f.action :submit, label: I18n.t("active_admin.reject")
    f.cancel_link return_to
  end
end

render partial: "attributes_table", locals: {document: resource.reload}
