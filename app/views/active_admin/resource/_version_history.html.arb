history ||= versions&.reverse || []

enum_labels = resource.class.defined_enums.transform_values(&:invert)
format_value = ->(field, value, id) {
  if field == "geojson"
    return "" if value.blank?

    dialog id: "history_#{id}_geojson_modal", title: Fmu.human_attribute_name(:geojson) do
      value
    end

    return link_to t("active_admin.view"), "javascript:void(0)", onclick: "document.querySelector('#history_#{id}_geojson_modal').showModal()"
  end

  enum_labels[field]&.fetch(value, nil)&.humanize || value.to_s
}

all_versions = if create_version.present?
  [create_version, *versions]
else
  versions
end

table_for history, class: "index_table" do
  column I18n.t("active_admin.versionate.event", default: "Event"), &:event
  column I18n.t("active_admin.versionate.created_at", default: "Date") do |v|
    v.created_at.strftime("%Y-%m-%d %H:%M")
  end
  column I18n.t("active_admin.versionate.user", default: "User") do |v|
    User.find_by(id: v.whodunnit)&.email
  end
  column I18n.t("active_admin.versionate.changes", default: "Changes") do |v|
    changes = v.changeset
    next if changes.blank?

    content_tag(:ul, style: "margin: 0; padding-left: 1.2em;") do
      safe_join(changes.map do |field, (old_val, new_val)|
        content_tag(:li) do
          content_tag(:b, field.humanize) +
            ": " + format_value.call(field, old_val, v.object_id.to_s + "_old") + " \u2192 " + format_value.call(field, new_val, v.object_id.to_s + "_new")
        end
      end)
    end
  end
  if all_versions.present?
    column I18n.t("active_admin.versionate.preview", default: "Preview") do |v|
      idx = all_versions.index(v)
      link_to t("active_admin.versionate.view"), url_for(version: idx) if idx
    end
  end
end
