upstream api_admin {
  server localhost:3000;
}

upstream portal {
  server localhost:5000;
}

<% if self_signed %>
server {
  listen 80;
  server_name <%= domain %>;
  return 301 https://$host$request_uri;
}
<% end %>

server {
<% if self_signed %>
  listen 443 ssl;
  ssl_certificate     /etc/nginx/ssl/self-signed.crt;
  ssl_certificate_key /etc/nginx/ssl/self-signed.key;
<% end %>
  server_name <%= domain.split(",").join(" ") %>;

  server_tokens off;
  <% domains = domain.split(",") %>
  <% if domains.count > 1 %>
    <% domains.drop(1).each do |d| %>

  if ($host = <%= d %>) {
    return 301 https://<%= domains.first %>$request_uri;
  }
    <% end %>
  <% end %>

  proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
  proxy_set_header X-Forwarded-Proto $scheme;
  proxy_set_header Host $host;
  proxy_hide_header X-Powered-By;
  proxy_http_version 1.1;
  proxy_set_header Upgrade $http_upgrade;
  proxy_set_header Connection "upgrade";
  proxy_cache_bypass $http_upgrade;
  proxy_set_header X-Sendfile-Type X-Accel-Redirect;
  proxy_set_header X-Accel-Mapping <%= api_dir %>/shared/uploads/=/files/;
  proxy_set_header X-Accel-Mapping <%= api_dir %>/shared/bundle/ruby/=/__gems_internal__/;

<% if auth_basic %>
  auth_basic "Restricted Content";
  auth_basic_user_file /etc/nginx/.htpasswd;

  # Let certbot's ACME HTTP-01 challenge through without basic auth.
  location ^~ /.well-known/acme-challenge/ {
    auth_basic off;
  }
<% end %>

  client_body_timeout 12;
  client_header_timeout 12;
  keepalive_timeout 15;
  send_timeout 10;

  client_body_buffer_size     128K;
  client_header_buffer_size   2k;
  client_max_body_size        1024m;
  large_client_header_buffers 4 16k;

  error_page 503 @503;

  # Return a 503 error if the maintenance page exists.
  if (-f <%= api_dir %>/shared/public/system/maintenance.html) {
    return 503;
  }

  rewrite ^/api/admin(/.*|$) /admin permanent;

  location ~ ^/api(/.*|$) {
    root <%= api_dir %>/current/public;
    auth_basic off;
    proxy_pass http://api_admin;
    proxy_redirect off;

    rewrite ^/api(/.*)$ $1 break;
  }

  location /__gems_internal__/ {
    alias <%= api_dir %>/shared/bundle/ruby/;
    internal;
  }

  location /files/ {
    internal;
    alias <%= api_dir %>/current/uploads/;
  }

  location = /health_check {
    root <%= api_dir %>/current/public;
    auth_basic off;
    proxy_pass http://api_admin;
    proxy_redirect off;
  }

  location ~ ^/(admin|uploads|private|rails)(/.*|$) {
    root <%= api_dir %>/current/public;

    proxy_connect_timeout       600;
    proxy_read_timeout          600;
    fastcgi_read_timeout        600;

    proxy_pass http://api_admin;
    proxy_redirect off;
  }

  # Rails assets
  location ~ ^/assets/ {
    root <%= api_dir %>/current/public;
    gzip_static on;
    expires max;
    add_header Cache-Control "public, immutable";
  }

<% if auth_basic %>
  location = /robots.txt {
    auth_basic off;
    proxy_pass http://portal;
    proxy_redirect off;
  }
<% end %>

  # Angular app
  location /observations-tool {
    rewrite ^([^.]*[^/])$ $1/ permanent;
  }

  location /observations-tool/ {
    alias <%= obs_tool_dir %>/dist/;
    index index.html;
    try_files $uri $uri/ /index.html =404;
  }

  # Next.js frontend
  location /_next/static/ {
    alias <%= portal_dir %>/.next/static/;
    brotli_static on;
    add_header Cache-Control "public, immutable";
    expires max;
    access_log off;
    log_not_found off;
  }

  location / {
    proxy_pass http://portal;
    proxy_redirect off;
  }

  location @503 {
    # Serve static assets if found.
    if (-f $request_filename) {
      break;
    }

    root <%= api_dir %>/shared/public;
    rewrite ^(.*)$ /system/maintenance.html break;
  }

  # For a real domain, certbot installs the certificate directives here;
  # for a bare IP the self-signed ssl_certificate lines above are used instead.
}
